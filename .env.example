APP_NAME="Evote Sender"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_LOCALE="sl"
APP_URL=http://sender.evote.local
DEPLOY_HOSTNAME_STAGING=
DEPLOY_DIRECTORY_STAGING=
DEPLOY_USER_STAGING=deploy
DEPLOY_HOSTNAME_PRODUCTION=
DEPLOY_DIRECTORY_PRODUCTION=

TAIL_HOST_PRODUCTION='evotesender'
TAIL_USER_PRODUCTION='deploy'
TAIL_LOG_DIRECTORY_PRODUCTION='/var/www/evoteappsender/current/storage/logs'
TAIL_LOG_FILE_PRODUCTION='laravel.log'

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=evote_db
DB_PORT=3306
DB_DATABASE=sender
DB_USERNAME=root
DB_PASSWORD=root

BROADCAST_DRIVER=log
CACHE_DRIVER=file
RATE_LIMITER_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=evote_mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=hrcek@eglasovanje.si
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=

# SES account max send rate (messages/second); paces outbound mail. Match your quota.
SES_MAX_SEND_RATE=14

# Outbound e-mail failure alerting (see config/mail-alerts.php).
MAIL_ALERTS_ENABLED=true
MAIL_ALERTS_TRANSPORT=log
MAIL_ALERTS_LOG_CHANNEL=slack
MAIL_ALERTS_MAIL_TO=
MAIL_ALERTS_MIN_FAILURES=1
MAIL_SEND_RETRY_HOURS=6
MAIL_SEND_MAX_EXCEPTIONS=8
# Slack webhook backing the 'slack' log channel (empty = no-op locally).
LOG_SLACK_WEBHOOK_URL=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Comma delimited list of authtokens that are valid
# These should be passed as a Authorization header
API_TOKEN_LIST=666666

